NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Пароль для входа на страницу статистики
STATS_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"

# Секрет для подписи cookie-JWT (должен быть длинным и случайным)
STATS_JWT_SECRET="CHANGE_ME_TO_A_LONG_RANDOM_SECRET"

# Секрет для Vercel Cron (для защиты endpoint /api/cron/update-stats)
CRON_SECRET="CHANGE_ME_TO_A_RANDOM_SECRET_FOR_CRON"

